# Supabase 연동 (대시보드: Settings → API)
# Project URL → VITE_SUPABASE_URL
# Publishable key (또는 anon key) → VITE_SUPABASE_ANON_KEY
# Secret key는 프론트엔드에 넣지 마세요 (서버 전용)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key

# 서울시 버스 도착 API (공공데이터포털 / data.seoul.go.kr 발급)
# Vercel Environment Variables에도 동일하게 등록 (VITE_ 접두사 없음)
SEOUL_BUS_API_KEY=your-seoul-bus-api-key

# 버스 API 일일 한도 전역 집계 — Vercel 서버(api/bus) 전용 (프론트에 넣지 마세요)
# SUPABASE_URL= (VITE_SUPABASE_URL 과 동일 프로젝트)
# SUPABASE_SERVICE_ROLE_KEY= (Settings → API → service_role secret)

# About 경력 상세 이력 열람 키 (채용 담당자 등에게 직접 전달)
# 설정하지 않으면 상세 열람 폼이 표시되지 않습니다
VITE_CAREER_UNLOCK_KEY=your-secret-key

# Web Push (탭이 꺼져도 일정 알림) — npm run vapid:generate 로 키 생성
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# 아래는 Supabase Edge Function(send-event-reminders) 시크릿에만 등록 (프론트에 넣지 마세요)
# VAPID_PUBLIC_KEY= (VITE_ 와 동일한 공개키)
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:your-email@example.com
# CRON_SECRET= (5분마다 Edge Function 호출 시 Authorization: Bearer 값)

# 읽기 전용 계정 — Edge Function(rotate-readonly-password) 시크릿에만 등록
# READONLY_USER_EMAIL=readOnly@dashboard.local
# READONLY_PASSWORD_PREFIX=Qkdzk!
# READONLY_OWNER_EMAIL=your-owner@gmail.com
# READONLY_INITIAL_PASSWORD= (선택, 최초 1회 setup 시)
# VITE_READONLY_AUTH_DOMAIN=dashboard.local (아이디-only 로그인 시 붙는 도메인)
