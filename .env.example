# Supabase 연동 (대시보드: Settings → API)
# Project URL → VITE_SUPABASE_URL
# Publishable key (또는 anon key) → VITE_SUPABASE_ANON_KEY
# Secret key는 프론트엔드에 넣지 마세요 (서버 전용)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your-key

# 서울시 버스 도착 API (공공데이터포털 / data.seoul.go.kr 발급)
# Vercel Environment Variables에도 동일하게 등록 (VITE_ 접두사 없음)
SEOUL_BUS_API_KEY=your-seoul-bus-api-key
